# Beautify Africa backend environment template
# Copy to .env for local development only.
# Do not commit real credentials. For production, source secrets from a managed secret store.

# Core runtime
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/beautify-africa
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend and API URL configuration
CLIENT_URL=http://localhost:5173
# Legacy aliases kept for compatibility in URL fallback logic
FRONT_END_URL=
FRONTEND_URL=
API_BASE_URL=http://localhost:5000

# Request limits
REQUEST_BODY_LIMIT=1mb

# Email delivery
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-password

# Payments
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Admin/auth controls
ADMIN_EMAILS=admin@example.com
ADMIN_DASHBOARD_PASSWORD=replace-admin-password

# Password reset flow
PASSWORD_RESET_URL_BASE=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Newsletter unsubscribe flow
NEWSLETTER_UNSUBSCRIBE_URL_BASE=http://localhost:5173/newsletter/unsubscribe
NEWSLETTER_UNSUBSCRIBE_TOKEN_TTL_MINUTES=60
